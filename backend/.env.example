# Port the server binds to (most hosts inject this automatically).
PORT=8000

# Database location. Defaults to a local SQLite file. For containers, point
# this at a mounted volume so data survives restarts, e.g.:
#   DATABASE_URL=sqlite:////data/lightai.db
DATABASE_URL=sqlite:///./lightai.db

# Comma-separated list of allowed CORS origins (your frontend URLs).
ALLOWED_ORIGINS=https://lightai-kohl.vercel.app,http://localhost:3000,http://localhost:5173

# Optional shared key for the SDK ingest endpoint. If set, /api/ingest requires
# an X-API-Key header matching this value. Leave empty to keep ingest open.
LIGHTAI_API_KEY=

# Optional GitHub webhook secret. If set, webhook signatures are verified.
GITHUB_WEBHOOK_SECRET=
